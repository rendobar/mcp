{
  "name": "@rendobar/mcp",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Rendobar — serverless media processing for AI agents",
  "homepage": "https://rendobar.com/docs/mcp/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rendobar/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/rendobar/mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rendobar",
    "ai",
    "video",
    "ffmpeg"
  ],
  "author": "Rendobar",
  "bin": {
    "rendobar-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.10"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "smoke": "node dist/bin.js --version",
    "inspector": "npx -y @modelcontextprotocol/inspector node dist/bin.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rendobar/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "msw": "^2.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "zod": "^3.25.0"
    }
  },
  "mcpName": "io.github.rendobar/mcp"
}
